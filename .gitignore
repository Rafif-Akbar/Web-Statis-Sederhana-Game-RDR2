## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
msbuild.log
msbuild.err
msbuild.wrn

# Visual Studio cache/options directory
.vs/

# NuGet packages (restored automatically via packages.config)
packages/
*.nupkg

# ReSharper / other tools
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider
.idea/

# Crash dumps
*.dmp

# Backup & report files
*.rdl.data
*.bak
*.tmp

# Publish profiles
*.pubxml
*.publishproj

# Auto-generated test result files
TestResult.xml

# OS files
.DS_Store
Thumbs.db
